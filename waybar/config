    "wlr/taskbar": {
    	"format": "{icon}",
    	"tooltip-format": "{title}",
    	"on-click": "activate",
    	"on-click-middle": "close",
    },
    "niri/workspaces": {
    	"disable-scroll": true,
    	"all-output": true,
    	"format": "{icon}",
    	"on-click": "activate",
    	"persistent-workspaces": {"*":[1,2,3,4,5,6,7,8,9]},
