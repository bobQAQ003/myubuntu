    "pulseaudio": {
    	"format": "<span color='#00FF7F'>{icon}</span>{volume}% ",
    	"format-muted": "<span color='#FF4040'> у°–Ғ </span>0% ",
    	"format-icons": {
      	  "headphone": "<span color='#BF00FF'> пҖҘ </span>",
      	  "hands-free": "<span color='#BF00FF'> пҖҘ </span>",
      	  "headset": "<span color='#BF00FF'> пҖҘ </span>",
      	  "phone": "<span color='#00FFFF'> пӮ• </span>",
      	  "portable": "<span color='#00FFFF'> пӮ• </span>",
      	  "car": "<span color='#FFA500'> пҶ№ </span>",
      	  "default": [
	      "<span color='#808080'> пҖҰ </span>",
              "<span color='#FFFF66'> пҖ§ </span>",
              "<span color='#00FF7F'> пҖЁ </span>"
          ]
        },
    	"on-click-right": "pavucontrol -t 3",
    	"on-click": "pactl -- set-sink-mute 0 toggle",
    	"tooltip": true,
    	"tooltip-format": "еҪ“еүҚзі»з»ҹеЈ°йҹі: {volume}%"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "пҶј",
            "default": "рҹҺң"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/poweroff": {
	"tooltip": false,
	"format": "пҖ‘",
	"on-click": "bash $HOME/.config/waybar/scripts/poweroff.sh"
    },
    "custom/weather": {
    	"return-type": "json",
    	"exec": "sh $HOME/.config/waybar/scripts/weather.sh",
    	"interval": 300,
    	"on-click": "firefox https://wttr.in"
    },
    "custom/window":{
    	"exec": "~/.config/waybar/scripts/window.sh",
    	"interval": 2,
    	"format": "{}",
    	"tooltip": false,
    	"escape": false
    },
    "custom/lock": {
    	"format": "<span color='#00FFFF'> пҖЈ </span>",
    	"on-click": "swaylock",  // ж”№дёәniriе…је®№зҡ„й”ҒеұҸе‘Ҫд»Ө
    	"tooltip": true,
    	"tooltip-format": "й”ҒеұҸ"
    },
