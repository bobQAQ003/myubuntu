        "format": "<span color='#FFD700'> пҖЎ </span>",
  	"on-click": "systemctl reboot",
  	"tooltip": true,
  	"tooltip-format": "йҮҚеҗҜ"
    },
    "custom/power": {
  	"format": "<span color='#FF4040'> пҖ‘ </span>",
  	"on-click": "systemctl poweroff",
  	"tooltip": true,
  	"tooltip-format": "е…іжңә"
